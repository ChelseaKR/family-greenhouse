{
  "name": "family-greenhouse",
  "version": "0.14.2",
  "license": "Elastic-2.0",
  "private": true,
  "description": "A shared plant-care journal for the whole household — per-plant schedules, reminders that find the right person across browser/email/SMS, and a care log everyone can see. React + TypeScript on AWS Lambda + DynamoDB + Cognito.",
  "keywords": [
    "plant-care",
    "houseplants",
    "gardening",
    "plant-tracker",
    "plant-reminder",
    "watering-reminder",
    "household",
    "family",
    "pwa",
    "react",
    "typescript",
    "serverless",
    "aws-lambda",
    "dynamodb",
    "terraform"
  ],
  "homepage": "https://familygreenhouse.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChelseaKR/family-greenhouse.git"
  },
  "bugs": {
    "url": "https://github.com/ChelseaKR/family-greenhouse/issues"
  },
  "author": "Chelsea Kelly-Reif",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "eval": "npm run eval --workspace backend",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm test && npm audit --omit=dev --audit-level=high && node scripts/check-no-bare-markers.mjs && node scripts/check-no-silenced-gates.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "tmp": "^0.2.6",
    "esbuild": "0.28.1",
    "js-yaml": "^4.2.0",
    "uuid": "^14.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
